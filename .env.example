# Management Panel API Environment Variables
# Copy this to .env and fill in the values

# Server
PORT=7008
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/management_panel?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL_OVERVIEW=60
REDIS_TTL_DEFAULT=300

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672